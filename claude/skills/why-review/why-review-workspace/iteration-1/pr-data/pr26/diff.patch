+name: CI
+
+on:
+  push:
+    branches: [main]
+  pull_request:
+
+jobs:
+  lint-and-test:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Prepare deploy key for sparkle-variables submodule
+        env:
+          DEPLOY_KEY: ${{ secrets.SUBMODULE_SSH_KEY }}
+        run: |
+          mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
+          printf '%s\n' "$DEPLOY_KEY" > "$HOME/.ssh/submodule_key"
+          chmod 600 "$HOME/.ssh/submodule_key"
+          ssh-keyscan -t ed25519 github.com >> "$HOME/.ssh/known_hosts" 2>/dev/null
+
+      - name: Fetch submodules
+        run: |
+          export GIT_SSH_COMMAND="ssh -i $HOME/.ssh/submodule_key -o IdentitiesOnly=yes -o UserKnownHostsFile=$HOME/.ssh/known_hosts"
+          git submodule update --init --recursive
+
+      - uses: actions/setup-node@v4
+        with:
+          node-version: "20"
+          cache: "npm"
+
+      - run: npm ci
+
+      - run: npm run lint
+
+      - run: npm test
diff --git a/.github/workflows/publish.yml b/.github/workflows/publish.yml
new file mode 100644
index 0000000..58764d5
--- /dev/null
+++ b/.github/workflows/publish.yml
@@ -0,0 +1,112 @@
+name: Publish to npm
+
+on:
+  workflow_dispatch:
+    inputs:
+      channel:
+        description: "Dist-tag を選択。auto は package.json の version から自動判定 (X.Y.Z-beta.N → beta / X.Y.Z → latest)。"
+        type: choice
+        required: true
+        default: auto
+        options:
+          - auto
+          - latest
+          - beta
+
+jobs:
+  publish:
+    runs-on: ubuntu-latest
+    permissions:
+      contents: read
+    steps:
+      - uses: actions/checkout@v4
+
+      - name: Prepare deploy key for sparkle-variables submodule
+        env:
+          DEPLOY_KEY: ${{ secrets.SUBMODULE_SSH_KEY }}
+        run: |
+          mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
+          printf '%s\n' "$DEPLOY_KEY" > "$HOME/.ssh/submodule_key"
+          chmod 600 "$HOME/.ssh/submodule_key"
+          ssh-keyscan -t ed25519 github.com >> "$HOME/.ssh/known_hosts" 2>/dev/null
+
+      - name: Fetch submodules
+        run: |
+          export GIT_SSH_COMMAND="ssh -i $HOME/.ssh/submodule_key -o IdentitiesOnly=yes -o UserKnownHostsFile=$HOME/.ssh/known_hosts"
+          git submodule update --init --recursive
+
+      - uses: actions/setup-node@v4
+        with:
+          node-version: "20"
+          registry-url: "https://registry.npmjs.org"
+          cache: "npm"
+
+      - run: npm ci
+
+      - run: npm run lint
+
+      - run: npm test
+
+      - name: Determine dist-tag
+        id: tag
+        env:
+          INPUT_CHANNEL: ${{ inputs.channel }}
+        run: |
+          set -euo pipefail
+          VERSION=$(node -p "require('./package.json').version")
+
+          case "$VERSION" in
+            *-beta.*) AUTO="beta" ;;
+            *-*)      AUTO="unsupported" ;;
+            *)        AUTO="latest" ;;
+          esac
+
+          if [ "$INPUT_CHANNEL" = "auto" ]; then
+            CHANNEL="$AUTO"
+          else
+            CHANNEL="$INPUT_CHANNEL"
+          fi
+
+          if [ "$CHANNEL" = "unsupported" ]; then
+            echo "::error::未対応の prerelease version です: $VERSION (サポートは -beta.N のみ)"
+            exit 1
+          fi
+
+          case "$CHANNEL:$VERSION" in
+            latest:*-*)
+              echo "::error::prerelease version ($VERSION) は latest へ publish できません"
+              exit 1
+              ;;
+            beta:*-*) ;;
+            beta:*)
+              echo "::error::安定版 ($VERSION) は beta へ publish できません。-beta.N を付けてください"
+              exit 1
+              ;;
+          esac
+
+          echo "version=$VERSION" >> "$GITHUB_OUTPUT"
+          echo "channel=$CHANNEL" >> "$GITHUB_OUTPUT"
+          echo "→ $VERSION を --tag $CHANNEL で publish します"
+
+      - name: npm publish
+        env:
+          NODE_AUTH_TOKEN: ${{ secrets.NPM_TOKEN }}
+          PUBLISH_TAG: ${{ steps.tag.outputs.channel }}
+        run: npm publish --tag "$PUBLISH_TAG"
+
+      - name: Summary
+        env:
+          PUBLISHED_VERSION: ${{ steps.tag.outputs.version }}
+          PUBLISHED_TAG: ${{ steps.tag.outputs.channel }}
+        run: |
+          {
+            echo "### Published"
+            echo ""
+            echo "- package: \`sparkle-design-cli\`"
+            echo "- version: \`$PUBLISHED_VERSION\`"
+            echo "- dist-tag: \`$PUBLISHED_TAG\`"
+            echo ""
+            echo "\`\`\`"
+            echo "npx --yes sparkle-design-cli@$PUBLISHED_TAG --help"
+            echo "\`\`\`"
+          } >> "$GITHUB_STEP_SUMMARY"
