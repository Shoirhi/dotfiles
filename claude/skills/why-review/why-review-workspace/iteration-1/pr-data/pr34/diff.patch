+    // Tailwind import を含まない globals.css を用意
+    // en: globals.css without any Tailwind import.
+    fs.writeFileSync(
+      path.join(tempDir, 'src', 'app', 'globals.css'),
+      '/* just a placeholder, no tailwindcss import */\n',
