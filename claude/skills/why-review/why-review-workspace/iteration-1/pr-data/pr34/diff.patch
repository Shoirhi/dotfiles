+test('generate --strict exits non-0 when sparkle-design is installed but no entry CSS exists', () => {
+  // package.json には sparkle-design が入っているのに entry CSS が一つも無い
+  // (Tailwind 未セットアップ) 場合、従来は warn + exit 0 だったが --strict で
+  // exit 1 になることを検証。
+  // en: Strict mode must surface the "package installed but no entry CSS"
+  // misconfiguration as a non-0 exit.
+  const tempDir = createTempDir();
+
+  try {
+    fs.writeFileSync(
+      path.join(tempDir, 'package.json'),
+      JSON.stringify(
+        { name: 'no-entry-css', dependencies: { 'sparkle-design': '^1.0.0' } },
+        null,
+        2
+      ),
+      'utf8'
+    );
+    fs.mkdirSync(path.join(tempDir, 'src', 'app'), { recursive: true });
+    fs.mkdirSync(path.join(tempDir, 'node_modules'), { recursive: true });
+    // entry CSS (globals.css / index.css) は一切作らない。sparkle.config.json だけ置く。
+    // en: No globals.css / index.css anywhere. Only the sparkle config.
+    fs.writeFileSync(
+      path.join(tempDir, 'sparkle.config.json'),
+      JSON.stringify({ primary: 'blue', 'font-pro': 'Inter', 'font-mono': 'Inter', radius: 'md' }),
+      'utf8'
+    );
+
+    const defaultResult = spawnSync(process.execPath, [CLI_PATH, 'generate'], {
+      cwd: tempDir,
+      encoding: 'utf8',
+    });
+    powerAssert(defaultResult.status === 0, 'default generate should stay warn-only (exit 0)');
+
+    const strictResult = spawnSync(process.execPath, [CLI_PATH, 'generate', '--strict'], {
+      cwd: tempDir,
+      encoding: 'utf8',
+    });
+    powerAssert(
+      strictResult.status !== 0,
+      `generate --strict should exit non-0 when entry CSS is missing (got ${strictResult.status})`
+    );
+  } finally {
+    removeTempDir(tempDir);
+  }
+});
