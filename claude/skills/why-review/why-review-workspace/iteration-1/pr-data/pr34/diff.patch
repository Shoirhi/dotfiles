+    const defaultResult = spawnSync(process.execPath, [CLI_PATH, 'generate'], {
+      cwd: tempDir,
+      encoding: 'utf8',
+    });
+    powerAssert(defaultResult.status === 0, 'default generate stays exit 0');
+
+    const strictResult = spawnSync(process.execPath, [CLI_PATH, 'generate', '--strict'], {
+      cwd: tempDir,
+      encoding: 'utf8',
+    });
